---
import MainLayout from "@/layouts/MainLayout.astro";
import FloatingDots from "@/components/FloatingDots.astro";
import BackgroundSVG from "@/components/BackgroundSVG.astro";
import ThemeIcon from "@/components/Theme.astro";
import HamburgerMenu from "@/components/HamburgerMenu.astro";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import "@/styles/global.css";

// import { initHeroHeight, initSmoothScroll } from "@/scripts/pageHelpers.js";

---

<MainLayout title="mulek.cc - Home">
  <TwSizeIndicator />

  <div class="relative w-full overflow-hidden min-h-screen md:h-[calc(100vh-3rem)]">

    <FloatingDots dotCount={160} clipPercent={50} />

    <div class="md:hidden absolute top-12 sm:top-32 left-0 w-full z-60 px-6 sm:px-16 pointer-events-none">
      <div class="flex justify-end items-center w-full pointer-events-auto">
        <div id="menu-wrapper" class="inline-flex items-center">
          <HamburgerMenu /> 
        </div>
      </div>
    </div>

    <section
      id="hero-section"
      class="absolute inset-0 flex items-start bg-body dark:bg-body-dark"
    >
      <div class="absolute inset-0 z-10">
        <BackgroundSVG />
      </div>

      <div class="relative z-20 w-full max-w-7xl mx-auto px-6 sm:px-16 grid grid-cols-1 lg:grid-cols-2 gap-8 pt-12 sm:pt-32">
        
        <!-- Left Column: Hero Info -->
        <div class="flex flex-col md:flex-row lg:flex-col items-start md:justify-between lg:justify-start text-neutral-800 dark:text-neutral-200 md:gap-12 lg:gap-0">
  
        <div class="flex flex-col space-y-2 w-full">
          <div class="flex items-center justify-between w-full">
            <h1 class="text-2xl xtall:text-3xl font-bold">Michael Mulek</h1>
            
          </div>

          <p class="text-base xtall:text-base font-medium">Systems Engineer</p>
          <p class="text-sm xtall:text-base">Let's dive into what I've been working on! 🚀💻</p>

          <div class="flex flex-row space-x-3 sm:space-x-4 mt-4">
            <a href="/about" class="px-2 py-2 md:px-6 md:py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent/90 transition">
              Learn More
            </a>
            <a href="/projects" class="px-2 py-2 md:px-6 md:py-3 border border-accent text-accent font-semibold rounded-lg hover:bg-accent/10 transition">
              View Projects
            </a>
          </div>
        </div>
        
        <nav class="hidden md:flex flex-col space-y-2 md:mt-0 lg:mt-8 pt-8 border-t border-neutral-300 dark:border-neutral-700 min-w-[120px]">
          <a href="/" class="nav-link active">Home</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/projects" class="nav-link">Projects</a>
          <a href="/blog" class="nav-link">Blog</a>
          <a href="/contact" class="nav-link">Contact</a>
        </nav>
      </div>

        <!-- Right Column: About Summary -->
        <div class="hidden md:flex flex-col items-center md:items-start text-center md:text-left text-neutral-800 dark:text-neutral-200">
          <h2 class="text-xl font-semibold mb-4 text-accent">About Me</h2>
          <div class="space-y-4 text-sm xtall:text-base">
            <p class="text-sm md:text-base">
              Hi, I'm Mike. I'm from Minnesota, where I live with my partner Chelsea and our four pets - dogs Gertie and Ducky, and cats Salem and Oliver.
            </p>
            <p class="text-sm md:text-base">
              I'm passionate about self-hosting and home lab projects.
              I love experimenting with new tools, managing my own infrastructure, and learning through
              hands-on projects that push me to understand systems at a deeper level.
            </p>
            <p class="text-sm md:text-base">
              I work as a Systems Engineer at
              <a href="https://www.vc3.com" target="_blank" rel="noopener noreferrer" class="text-accent font-semibold hover:underline">VC3</a>,
              helping businesses optimize their IT environments. I bring over 6 years of professional experience in the industry, with a background spanning infrastructure, automation, and technical support.
            </p>
            <p class="text-sm md:text-base">
              Feel free to reach out through my <a href="/contact" class="text-accent font-semibold hover:underline">contact page</a> - I'd love to connect.
            </p>
            <a href="/about" class="inline-block text-accent font-semibold hover:underline text-sm">Learn more →</a>
          </div>
        </div>

      </div>
    </section>
  </div>

  <div
    id="hidden-menu"
    class="hidden-menu fixed inset-0 bg-neutral-100/90 dark:bg-neutral-900/90 backdrop-blur-md
          flex flex-col items-center justify-center overflow-auto z-50 md:hidden"
  >
    <ul class="flex flex-col p-4 space-y-6 text-neutral-800 dark:text-neutral-200 text-3xl font-bold text-center">
      <li><a href="/" class="hover:text-accent transition">Home</a></li>
      <li><a href="/about" class="hover:text-accent transition">About</a></li>
      <li><a href="/projects" class="hover:text-accent transition">Projects</a></li>
      <li><a href="/blog" class="hover:text-accent transition">Blog</a></li>
      <li><a href="/contact" class="hover:text-accent transition">Contact</a></li>
    </ul>

    <div class="mt-12 pt-8 border-t border-neutral-300 dark:border-neutral-700 w-24 flex justify-center">
      <ThemeIcon />
    </div>
  </div>
</div>

</MainLayout>
<script type="module">
  import { initHeroHeight, initSmoothScroll } from "/scripts/pageHelpers.js";

  document.addEventListener('astro:page-load', () => {
    // initHeroHeight();
    initSmoothScroll();
  });
</script>

<script>
  function setupMobileMenu() {
    const menuBtn = document.getElementById('menu-btn') as HTMLInputElement;
    const body = document.body;
    const hiddenMenu = document.getElementById('hidden-menu');

    if (menuBtn && hiddenMenu) {
      menuBtn.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        
        if (target.checked) {
          body.classList.add('menu-open');
        } else {
          body.classList.remove('menu-open');
        }
      });

      hiddenMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menuBtn.checked = false;
          body.classList.remove('menu-open');
        });
      });
    }
  }

  document.addEventListener('astro:page-load', setupMobileMenu);
</script>
