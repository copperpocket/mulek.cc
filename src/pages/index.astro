---
// src/pages/index.astro

import MainLayout from "@/layouts/MainLayout.astro";
import FloatingDots from "@/components/FloatingDots.astro";
import BackgroundSVG from "@/components/BackgroundSVG.astro";
import ThemeIcon from "@/components/Theme.astro";
import HamburgerMenu from "@/components/HamburgerMenu.astro";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import AboutSummary from "@/components/AboutSummary.astro";
import "@/styles/global.css";

---

<script type="module">
  import "/scripts/menu-toggle.js";
</script>

<MainLayout title="mulek.cc - Home">
  <TwSizeIndicator />

  <div class="relative w-full overflow-hidden min-h-screen md:h-[calc(100vh-3rem)]">

    <FloatingDots dotCount={160} clipPercent={50} />

    <div class="sm:hidden fixed top-8 left-0 w-full z-60 px-12 pointer-events-none">
      <div class="flex justify-end items-center w-full pointer-events-auto">
        
        <div class="p-2 rounded-full">
          <ThemeIcon />
        </div>

        <div id="menu-wrapper" class="inline-flex items-center p-2 rounded-full">
          <HamburgerMenu /> 
        </div>
        
      </div>
    </div>

    <section
      id="hero-section"
      class="absolute inset-0 flex items-center justify-center bg-body dark:bg-body-dark"
    >
      <div class="absolute inset-0 z-10">
        <BackgroundSVG />
      </div>

      <div class="relative z-20 w-full max-w-7xl mx-auto px-6 sm:px-16 grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Left Column: Hero Info -->
        <div class="flex flex-col sm:flex-row lg:flex-col items-center sm:items-start sm:justify-between lg:justify-start text-neutral-800 dark:text-neutral-200 sm:gap-12 lg:gap-0">
  
          <div class="flex flex-col space-y-3 w-fit sm:w-full text-left">
            <div class="flex items-center justify-between w-full">
              <h1 class="text-4xl font-bold">Michael Mulek</h1>
            </div>

            <p class="text-lg font-medium">Systems Engineer</p>
            <p class="text-base">Learn a bit about who I am and the work I’ve done.</p>

            <div class="flex flex-row space-x-3 sm:space-x-4 mt-4">
              <a href="/about" class="px-4 py-2 sm:px-6 sm:py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent/90 transition">
                About Me
              </a>
              <a href="/projects" class="px-4 py-2 sm:px-6 sm:py-3 border border-accent bg-body dark:bg-body-dark text-accent font-semibold rounded-lg hover:bg-accent/10 transition">
                My Projects
              </a>
            </div>
          </div>
          
          <nav class="hidden sm:flex flex-col space-y-2 md:mt-0 lg:mt-8 pt-8 border-t border-neutral-300 dark:border-neutral-700 min-w-[120px]">
            <a href="/about" class="nav-link">About</a>
            <a href="/blog" class="nav-link">Blog</a>
            <a href="/contact" class="nav-link">Contact</a>
            <a href="/projects" class="nav-link">Projects</a>
          </nav>
        </div>

        <!-- Right Column: About Summary -->
        <div class="hidden sm:flex flex-col items-center sm:items-start text-center sm:text-left text-neutral-800 dark:text-neutral-200">
          <AboutSummary />
        </div>

      </div>
    </section>
  </div>

  <div
    id="hidden-menu"
    class="hidden-menu fixed inset-0 bg-neutral-100/60 dark:bg-neutral-900/60 backdrop-blur-sm
          flex flex-col items-center justify-center overflow-auto z-50 md:hidden"
  >
    <ul class="flex flex-col p-4 space-y-6 text-neutral-800 dark:text-neutral-200 text-3xl font-bold text-center">
      <li><a href="/" class="hover:text-accent transition">Home</a></li>
      <li><a href="/about" class="hover:text-accent transition">About</a></li>
      <li><a href="/projects" class="hover:text-accent transition">Projects</a></li>
      <li><a href="/blog" class="hover:text-accent transition">Blog</a></li>
      <li><a href="/contact" class="hover:text-accent transition">Contact</a></li>
    </ul>

  </div>
</div>

</MainLayout>

<script>
  function checkBirthdays() {
    const today = new Date();
    const currentMonthDay = `${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
    
    const birthdaySpans = document.querySelectorAll('[data-bday]');
    
    birthdaySpans.forEach(span => {
      // Clear previous content to avoid double emojis if the event fires twice
      span.textContent = ''; 
      
      if (span.getAttribute('data-bday') === currentMonthDay) {
        span.textContent = ' 🎂';
        span.classList.add('animate-bounce', 'inline-block');
      }
    });
  }

  // Listen for Astro's page load event to handle View Transitions
  document.addEventListener('astro:page-load', () => {
    checkBirthdays();
  });
</script>