---
import MainLayout from "@/layouts/MainLayout.astro";
import FloatingDots from "@/components/FloatingDots.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

const HCAPTCHA_SITE_KEY = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY;
---
<MainLayout title="Contact - mulek.cc" description="Get in touch with Michael Scott Mulek. Have a question, project idea, or just want to say hello?">
  <FloatingDots />
  <Header />

  <main class="relative z-20 container mx-auto py-16 text-neutral-800 dark:text-neutral-200">
    
    <section id="contact-hero" class="pt-24 pb-12 flex flex-col items-center text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-accent mb-4">Get in Touch</h1>
      <p class="text-lg max-w-2xl">
        Have a question, a project idea, or just want to say hello?
        I'm always open to connecting with other developers and creators.
      </p>
    </section>

    <section id="contact-form-section" class="mt-8 mb-16 flex flex-col items-center">
      <div
        id="card-contact"
        class="rounded-2xl p-6 w-full max-w-xl flex flex-col space-y-4 bg-[color:theme(colors.accent/20%)] dark:bg-neutral-900 shadow-xl"
      >
        <form class="flex flex-col space-y-3" id="contact-form">
          <input
            type="text"
            name="name"
            placeholder="Your Name"
            required
            class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-accent text-sm"
          />
          <input
            type="email"
            name="email"
            placeholder="Your Email"
            required
            class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-accent text-sm"
          />
          <textarea
            name="message"
            placeholder="Your Message"
            rows="4"
            required
            class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-accent text-sm resize-none"
          ></textarea>

          <div
            class="h-captcha"
            data-sitekey={HCAPTCHA_SITE_KEY}
          ></div>

          <button
            type="submit"
            id="submit-button"
            class="text-sm md:text-base bg-accent text-white font-semibold rounded-lg px-4 py-2 hover:bg-accent/90 transition"
          >
            Send Message
          </button>
        </form>

        <div id="form-status" class="text-center text-sm font-semibold"></div>

        <div class="flex justify-center items-center space-x-6 mt-4 text-sm">
          <a href="https://copperpocket.bsky.social" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Bluesky</a>
          <a href="https://github.com/copperpocket" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">GitHub</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">LinkedIn</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</MainLayout>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
<script type="module">
  import { setupFormHandler } from "/scripts/contactFormHandler.js";

  document.addEventListener('astro:page-load', () => {
    setupFormHandler();
  });
</script>
