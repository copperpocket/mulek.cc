---
import MainLayout from "@/layouts/MainLayout.astro";
import Avatar from "@/components/Avatar.astro";
import FloatingDots from "@/components/FloatingDots.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
---

<MainLayout title="About - mulek.cc" description="Learn more about Michael Scott Mulek - Systems Engineer, homelab enthusiast, and developer.">
  <TwSizeIndicator />
  <FloatingDots dotCount={400} />
  <Header />

  <main class="relative z-20 container mx-auto pt-8 sm:pt-16 pb-8 px-4 text-neutral-800 dark:text-neutral-200">
    
    <section id="about-hero" class="flex flex-col items-center text-center">
      <Avatar />
      <h1 class="text-4xl md:text-5xl font-extrabold text-accent mb-4 mt-4">About Me</h1>
    </section>

    <section id="about-me" class="flex flex-col items-center">
      <div id="card-about-me"
        class="w-full max-w-3xl p-6 rounded-xl space-y-4 
               bg-accent/20 dark:bg-neutral-900 shadow-xl"
      >
        <p class="text-sm md:text-base">
          Hi, I'm Mike. I'm from Minnesota, where I live with my partner Chelsea and our four pets - dogs Gertie and Ducky, and cats Salem and Oliver.
        </p>
        <p class="text-sm md:text-base">
          I'm passionate about self-hosting and home lab projects.
          I love experimenting with new tools, managing my own infrastructure, and learning through
          hands-on projects that push me to understand systems at a deeper level.
        </p>
        <p class="text-sm md:text-base">
          I work as a Systems Engineer at
          <a href="https://www.vc3.com" target="_blank" rel="noopener noreferrer" class="text-accent font-semibold hover:underline">VC3</a>,
          helping businesses optimize their IT environments. I bring over 6 years of professional experience in the industry, with a background spanning infrastructure, automation, and technical support.
        </p>
        <p class="text-sm md:text-base">
          Feel free to reach out through my <a href="/contact" class="text-accent font-semibold hover:underline">contact page</a> - I'd love to connect.
        </p>
      </div>
    </section>

    <section id="about-site" class="mt-16 mb-24 flex flex-col items-center">
      <h2 class="text-2xl font-semibold mb-4 text-center">About This Site</h2>
      
      <div id="card-about-site"
        class="w-full max-w-3xl p-6 rounded-xl space-y-4 
               bg-accent/20 dark:bg-neutral-900 shadow-xl text-center"
      >
        <p class="text-sm md:text-base">
          Welcome! This site showcases my projects, experience, and my passion for creating and exploring technology.
        </p>
        <p class="text-sm md:text-base">
          Explore my
          <a href="/projects" class="text-accent font-semibold hover:underline">Projects</a>
          — the work I've built, from personal websites to servers and game prototypes.
        </p>
        <p class="text-sm md:text-base">
          Check out my
          <a href="/blog" class="text-accent font-semibold hover:underline">Blog</a>
          — articles on various tech topics and my homelab journey.
        </p>
        <p class="text-sm md:text-base">
          <a href="/contact" class="text-accent font-semibold hover:underline">Get in Touch</a>
          — reach out if you have questions, collaboration ideas, or just want to say hello.
        </p>
        <p class="text-sm md:text-base">
          The goal is to provide a minimal, clean experience while giving you a quick overview of what I do and how we can connect.
        </p>
      </div>
    </section>



    <section id="about-technical" class="mt-16 mb-24 flex flex-col items-center">
      <h2 class="text-2xl font-semibold mb-4 text-center">My Technical Foundation</h2>
      
      <div id="tech-card"
        class="w-full max-w-4xl p-6 md:p-10 rounded-xl space-y-6 
               bg-accent/20 dark:bg-neutral-900 shadow-xl"
      >
        <p class="text-sm md:text-base">
          As a Systems Engineer, my core philosophy is rooted in **automation, reliability, and security**. I believe that robust systems are built on strong fundamentals—infrastructure as code, proactive monitoring, and a security-first mindset.
        </p>
        
        <h3 class="text-lg font-bold text-accent">Key Areas of Expertise:</h3>
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-y-2 text-sm md:text-base list-disc list-inside ml-4">
          <li>Cloud Services (AWS, Azure)</li>
          <li>Automation (PowerShell, Python)</li>
          <li>Virtualization (VMware, Hyper-V)</li>
          <li>Networking & Infrastructure</li>
          <li>Linux Administration</li>
          <li>System Monitoring (Grafana, Prometheus)</li>
        </ul>
        
        <p class="text-sm md:text-base italic pt-4 border-t border-accent/30">
          I thrive on complexity and am constantly seeking new ways to optimize workflows, whether it's managing enterprise environments or building out my personal homelab.
        </p>
      </div>
    </section>

    <section id="about-timeline" class="mt-16 mb-24 mx-4 flex flex-col items-center">
      <h2 class="text-2xl font-semibold mb-8 text-center">Professional Timeline</h2>

      <div class="w-full max-w-3xl relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-accent opacity-50 hidden sm:block"></div>

        <div class="relative mb-8 flex justify-between items-center w-full">
          <div class="w-full sm:w-1/2 sm:pr-8">
            <h4 class="font-bold text-lg text-accent">Systems Engineer</h4>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">VC3 (Current)</p>
            <p class="text-xs mt-1">Leading infrastructure projects, automating maintenance tasks, and providing top-tier systems support for diverse clients.</p>
          </div>
          <div class="z-10 w-4 h-4 rounded-full bg-accent absolute left-1/2 transform -translate-x-1/2 hidden sm:block"></div>
          <div class="w-full sm:w-1/2"></div>
        </div>

        <div class="relative mb-8 flex justify-between items-center w-full flex-row-reverse">
          <div class="w-full sm:w-1/2 sm:pl-8 text-left sm:text-right">
            <h4 class="font-bold text-lg text-accent">IT Support Specialist</h4>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">ABC Company</p>
            <p class="text-xs mt-1">Managed desktop deployments, provided network troubleshooting, and contributed to security audits.</p>
          </div>
          <div class="z-10 w-4 h-4 rounded-full bg-accent absolute left-1/2 transform -translate-x-1/2 hidden sm:block"></div>
          <div class="w-full sm:w-1/2"></div>
        </div>

        <div class="relative mb-8 flex justify-between items-center w-full">
          <div class="w-full sm:w-1/2 sm:pr-8">
            <h4 class="font-bold text-lg text-accent">B.S. Computer Science</h4>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">University XYZ</p>
            <p class="text-xs mt-1">Specialized in operating systems and distributed computing.</p>
          </div>
          <div class="z-10 w-4 h-4 rounded-full bg-accent absolute left-1/2 transform -translate-x-1/2 hidden sm:block"></div>
          <div class="w-full sm:w-1/2"></div>
        </div>

      </div>
    </section>

    <section id="about-cta" class="mt-16 pt-12 border-t border-accent/30 flex flex-col items-center text-center">
      <p class="text-lg mb-6">
        Want to know more or discuss a potential project?
      </p>
      <a
        href="/contact"
        class="px-8 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent/90 transition shadow-lg"
      >
        Get in Touch
      </a>
    </section>

  </main>

  <Footer />
</MainLayout>
