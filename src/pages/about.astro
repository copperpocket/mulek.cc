---
// src/pages/about.astro

// Layout wrapper providing <head>, metadata, and global structure
import MainLayout from "@/layouts/MainLayout.astro";

// Reusable UI components
import Avatar from "@/components/Avatar.astro";
import FloatingDots from "@/components/FloatingDots.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import AboutSummary from "@/components/AboutSummary.astro";
import AboutTimelineItem from "@/components/AboutTimelineItem.astro";

// Global styles (Tailwind + overrides)
import "@/styles/global.css";
---

<!--
  MainLayout:
  - Sets page title + meta description (SEO)
  - Wraps all content in consistent layout (header/footer handled externally)
-->
<MainLayout title="About - mulek.cc" description="Learn more about Michael Scott Mulek - Systems Engineer, homelab enthusiast, and developer.">
  
  <!-- Dev utility: shows current Tailwind breakpoint -->
  <TwSizeIndicator />

  <!-- Decorative animated background layer -->
  <FloatingDots dotCount={400} />

  <!-- Global site header -->
  <Header />

  <!--
    Main content container
    - z-20 ensures content sits above background effects
    - container + mx-auto centers content
    - consistent vertical spacing applied here
  -->
  <main class="relative z-20 container mx-auto pt-16 pb-8 px-4 text-neutral-800 dark:text-neutral-200">

    <!-- HERO SECTION -->
    <!-- Centered intro with avatar + title -->
    <section id="about-hero" class="flex flex-col items-center text-center">
      <Avatar />
      <h1 class="text-4xl md:text-5xl font-extrabold mt-4 mb-4">About Me</h1>
    </section>
    <!-- ABOUT SUMMARY -->
    <!-- Card wrapper for reusable summary component -->
    <section id="about-me" class="flex flex-col items-center">
      <div id="card-about-me" class="w-full max-w-3xl p-6 rounded-xl space-y-4 bg-accent/20 dark:bg-neutral-900 shadow-xl">
        <AboutSummary />
      </div>
    </section>

    <!-- EXPERIENCE TIMELINE -->
    <!--
      Custom vertical timeline:
      - Center line (absolute)
      - Alternating left/right entries using flex + reverse
      - Hidden on small screens for simpler layout
    -->
    <section id="about-timeline" class="mt-16 pt-16 border-t border-accent/30 flex flex-col items-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-8">Experience</h2>

      <div class="w-full max-w-4xl p-6 md:p-10 rounded-xl bg-accent/20 dark:bg-neutral-900 shadow-xl">
        <div class="relative w-full max-w-3xl mx-auto">

          <div class="absolute left-1/2 transform -translate-x-1/2 w-0.5 h-full bg-accent/30 hidden sm:block"></div>

          <AboutTimelineItem
            title="Internal IT Systems Engineer I"
            date="2023 - 2026"
            company="VC3"
            description="Leading internal infrastructure projects and developing advanced automation workflows to streamline enterprise operations."
            side="left"
          />

          <AboutTimelineItem
            title="Infrastructure Engineer I"
            date="2022 - 2023"
            company="CW Technology"
            description="Maintained complex server environments and spearheaded high-stakes client offboarding projects within a fast-paced MSP environment."
            side="right"
          />

          <AboutTimelineItem
            title="Help Desk Technician I"
            date="2021 - 2022"
            company="CW Technology"
            description="Provided rapid-response technical support and served as the primary technical point of contact for a diverse MSP client base."
            side="left"
          />

          <AboutTimelineItem
            title="IT Support Specialist"
            date="2018 - 2021"
            company="Superior Choice Credit Union"
            description="Managed multi-branch desktop environments and handled on-site infrastructure support alongside critical security and compliance audits."
            side="right"
          />

          <AboutTimelineItem
            title="Computer & Web Programming"
            date="2014 - 2017"
            company="Lake Superior College"
            description="Deep dive into computer science fundamentals, full-stack development, and graphic design, building the core foundation for my engineering career."
            side="left"
          />
        </div>
      </div>
    </section>

    <!-- PHILOSOPHY SECTION -->
    <!--
      Three-column responsive grid:
      - Collapses to single column on mobile
      - Each item represents a core principle
    -->
    <section id="about-philosophy" class="mt-16 pt-16 border-t border-accent/30 flex flex-col items-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-8">Philosophy</h2>
      
      <div id="tech-card" class="w-full max-w-4xl p-6 md:p-10 rounded-xl space-y-10 bg-accent/20 dark:bg-neutral-900 shadow-xl">

        <!-- Intro paragraph -->
        <p class="text-sm md:text-base leading-relaxed max-w-2xl mx-auto text-center">
          I've always been driven by the need to understand how things work under the hood. That curiosity usually turns a quick fix into a weekend-long project, where the goal isn't just to get it running, but to rebuild it better, faster, and more efficient than it was before.
        </p>

        <!-- Principles grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center space-y-3">
            <div class="text-accent text-2xl">🛠️</div>
            <h3 class="text-lg font-bold">Ownership</h3>
            <p class="text-xs opacity-80 leading-relaxed">
              I believe in self-hosting and digital sovereignty. If it’s critical, it should run on hardware I control and infrastructure I understand from the ground up.
            </p>
          </div>

          <!-- Principle: Resiliency -->
          <div class="text-center space-y-3">
            <div class="text-accent text-2xl">🔒</div>
            <h3 class="text-lg font-bold">Resiliency</h3>
            <p class="text-xs opacity-80 leading-relaxed">
              Systems should be built to survive. I prioritize security, redundancy, and high availability - not because it's easy, but because reliable systems are invisible.
            </p>
          </div>

          <!-- Principle: Iteration -->
          <div class="text-center space-y-3">
            <div class="text-accent text-2xl">📈</div>
            <h3 class="text-lg font-bold">Iteration</h3>
            <p class="text-xs opacity-80 leading-relaxed">
              Optimization is a continuous process. I’m never truly "done" with a project; there is always a way to refactor, simplify, or squeeze out more performance.
            </p>
          </div>
        </div>
        
        <!-- Closing quote -->
        <div class="pt-6 border-t border-accent/30 text-center">
          <p class="text-sm italic opacity-80">
            "If you have to do it twice, automate it."
          </p>
        </div>
      </div>
    </section>

    <!-- ABOUT SITE -->
    <!-- Explains purpose of the site and links to key sections -->
    <section id="about-site" class="mt-16 pt-16 border-t border-accent/30 flex flex-col items-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-8">About Site</h2>
      
      <div id="card-about-site" class="w-full max-w-3xl p-6 rounded-xl space-y-4 bg-accent/20 dark:bg-neutral-900 shadow-xl text-center">
        <p class="text-sm md:text-base">
          This site showcases my projects, experience, and my passion for creating and exploring technology.
        </p>

        <!-- Internal navigation links -->
        <p class="text-sm md:text-base">
          Explore my
          <a href="/projects" class="text-accent font-semibold hover:underline">Projects</a>
          — the work I've built, from personal websites to servers and game prototypes.
        </p>
        <p class="text-sm md:text-base">
          Check out my
          <a href="/blog" class="text-accent font-semibold hover:underline">Blog</a>
          — articles on various tech topics and my homelab journey.
        </p>
        <p class="text-sm md:text-base">
          The goal is to provide a minimal, clean experience while giving you a quick overview of what I do and how we can connect.
        </p>
      </div>
    </section>

    <!-- CALL TO ACTION -->
    <!-- Final conversion section encouraging user interaction -->
    <section id="about-cta" class="mt-16 pt-16 border-t border-accent/30 flex flex-col items-center text-center">
      <p class="text-lg mb-6">
        Want to know more or discuss a potential project?
      </p>

      <!-- Primary CTA button -->
      <a href="/contact" class="px-8 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent/90 transition shadow-lg">
        Get in Touch
      </a>
    </section>
  </main>

  <!-- Global footer -->
  <Footer />
</MainLayout>