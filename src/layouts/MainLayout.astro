---
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title || 'mulek.cc'}</title>
        <meta name="description" content={description || 'Personal website of Michael Scott Mulek'} />
        <script is:inline>
          (function() {
            const saved = localStorage.getItem("theme");
            const html = document.documentElement;
            if (saved === "light") {
              html.classList.remove("dark");
            } else if (saved === "dark") {
              html.classList.add("dark");
            } else {
              if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                html.classList.add("dark");
              }
            }
          })();
        </script>
        <ClientRouter />
    </head>
  <body class="bg-body dark:bg-body-dark text-neutral-800 dark:text-neutral-200 h-full">
    <main id="main-content" class="relative min-h-full">
      <slot />
    </main>
  </body>
</html>
