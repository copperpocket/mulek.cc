---
import ThemeIcon from "./Theme.astro";
import HamburgerMenu from "./HamburgerMenu.astro";

interface Props {
  hideLogo?: boolean;
  navBreakpoint?: 'md' | 'lg';
  
}

const { hideLogo = false, navBreakpoint = 'md' } = Astro.props;

// Map the prop to the full class string
const breakpointClasses = {
  md: 'md:flex',
  lg: 'lg:flex',
};

// Use the mapped value
const displayClass = breakpointClasses[navBreakpoint];

const pathname = Astro.url.pathname;
const isActive = (path: string) => 
  pathname === path || (path !== '/' && pathname.startsWith(path));
---

<header
  id="site-header"
  class="w-full sticky top-0 z-40 flex items-center min-h-12"
>
  <div id="header-nav"
       class="mx-auto flex items-center justify-between w-full 
              relative transition-all duration-300 px-8">
  <span id="nav-border"
      class="absolute bottom-0 left-0 h-[2px] w-full bg-accent opacity-0 translate-y-25 transition-all duration-300">
  </span>

    {hideLogo !== true && (
    <div id="logo-wrapper" 
         class="inline-flex transform origin-left transition-all duration-300 h-0 translate-y-[32px] items-center xtall:pl-4">
        <a href="/" class="flex items-center space-x-2 text-xl xtall:text-2xl text-neutral-800 dark:text-neutral-200">mulek.cc</a>
    </div>
    )}

    <nav id="nav-links-wrapper" 
         class={`hidden ${displayClass} items-center space-x-4 
                transform transition-all duration-300 h-0 translate-y-[32px]`}>
      <a href="/" class:list={["nav-link", { "active": isActive('/') }]}>Home</a>
      <a href="/about" class:list={["nav-link", { "active": isActive('/about') }]}>About</a>
      <a href="/projects" class:list={["nav-link", { "active": isActive('/projects') }]}>Projects</a>
      <a href="/blog" class:list={["nav-link", { "active": isActive('/blog') }]}>Blog</a>
      <a href="/contact" class:list={["nav-link", { "active": isActive('/contact') }]}>Contact</a>
    </nav>

    <div class="flex items-end space-x-6 xtall:space-x-10"> 
      <div id="theme-wrapper" 
            class="inline-flex transform transition-all duration-300 h-0 translate-y-[32px] items-center">
            <ThemeIcon />
        </div>

        <div id="menu-wrapper" 
            class="inline-flex z-50 transition-all duration-300 h-0 translate-y-[32px] items-center xtall:pr-4 md:hidden">
            <HamburgerMenu /> 
        </div>
    </div>


    <div
      id="hidden-menu"
      class="hidden-menu fixed inset-0 bg-neutral-100/60 dark:bg-neutral-900/60 backdrop-blur-sm
             flex items-center justify-center overflow-auto z-40 md:hidden"
    >
      <ul class="flex flex-col p-4 space-y-4 text-neutral-800 dark:text-neutral-200 text-2xl">
        <li><a href="/" class="hover:text-blue-500">Home</a></li>
        <li><a href="/about" class="hover:text-blue-500">About</a></li>
        <li><a href="/projects" class="hover:text-blue-500">Projects</a></li>
        <li><a href="/blog" class="hover:text-blue-500">Blog</a></li>
        <li><a href="/contact" class="hover:text-blue-500">Contact</a></li>
      </ul>
    </div>
  </div>
</header>

<script type="module">
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById("site-header");
    if (!header) return;
    const logoWrapper = document.getElementById("logo-wrapper");
    const navLinksWrapper = document.getElementById("nav-links-wrapper");
    const themeWrapper = document.getElementById("theme-wrapper");
    const menuWrapper = document.getElementById("menu-wrapper");
    const navBorder = document.getElementById("nav-border"); 
    const isRootPage = window.location.pathname === '/';

    function updateHeader() {
      if (!isRootPage || window.scrollY > 30) {
        if (logoWrapper) {
          logoWrapper.classList.remove("translate-y-[32px]");
          logoWrapper.classList.add("translate-y-0");
          logoWrapper.classList.add("scale-75");
        }
        if (navLinksWrapper) {
          navLinksWrapper.classList.remove("translate-y-[32px]");
          navLinksWrapper.classList.add("translate-y-0");
        }
        if (themeWrapper) {
          themeWrapper.classList.remove("translate-y-[32px]");
          themeWrapper.classList.add("translate-y-0");
          themeWrapper.classList.add("scale-75");
        }
        if (menuWrapper) {
          menuWrapper.classList.remove("translate-y-[32px]");
          menuWrapper.classList.add("translate-y-0");
          menuWrapper.classList.add("scale-75");
        }

        navBorder.classList.remove("opacity-0", "translate-y-25");
        navBorder.classList.add("opacity-90", "translate-y-6");  

        header.classList.add("bg-body", "dark:bg-body-dark");
      } else {
        if (logoWrapper) {
          logoWrapper.classList.add("translate-y-[32px]");
          logoWrapper.classList.remove("translate-y-0");
          logoWrapper.classList.remove("scale-75");
        }
        if (navLinksWrapper) {
          navLinksWrapper.classList.add("translate-y-[32px]");
          navLinksWrapper.classList.remove("translate-y-0");
        }
        if (themeWrapper) {
          themeWrapper.classList.add("translate-y-[32px]");
          themeWrapper.classList.remove("translate-y-0");
          themeWrapper.classList.remove("scale-75");
        }
        if (menuWrapper) {
          menuWrapper.classList.add("translate-y-[32px]");
          menuWrapper.classList.remove("translate-y-0");
          menuWrapper.classList.remove("scale-75");
        }

        header.classList.remove("bg-body", "dark:bg-body-dark");

        navBorder.classList.remove("opacity-90", "translate-y-6");
        navBorder.classList.add("opacity-0", "translate-y-25");
      }
    }

    window.addEventListener("scroll", updateHeader );
    updateHeader();
  });
</script>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuBtn = document.getElementById('menu-btn');
    const body = document.body;

    if (menuBtn) {
      menuBtn.addEventListener('change', () => {
        if ((menuBtn as HTMLInputElement).checked) {
          body.classList.add('menu-open');
        } else {
          body.classList.remove('menu-open');
        }
      });

      document.querySelectorAll('#hidden-menu a').forEach(link => {
          link.addEventListener('click', () => {
              (menuBtn as HTMLInputElement).checked = false;
              body.classList.remove('menu-open');
          });
      });
    }
  });
</script>