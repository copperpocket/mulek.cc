<div id="pet-modal" class="fixed inset-0 z-100 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-md transition-opacity">
  <div class="relative max-w-lg w-full bg-neutral-100 dark:bg-neutral-800 rounded-xl overflow-hidden shadow-2xl transform transition-all scale-25 opacity-0" id="modal-content">
    
    <button 
      id="close-modal" 
      class="absolute top-4 right-4 z-20 p-2 
             bg-white dark:bg-neutral-900
             rounded-full shadow-lg border border-neutral-300 dark:border-neutral-700
             transition-all duration-200 hover:scale-110 active:scale-95 group"
      aria-label="Close modal"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
      </svg>
    </button>
    
    <img id="modal-img" src="" alt="Pet Photo" class="w-full h-auto object-cover max-h-[75vh]" />
    
    <div class="p-5 text-center bg-white dark:bg-neutral-800">
      <p id="modal-caption" class="font-bold text-xl text-neutral-800 dark:text-neutral-100"></p>
    </div>
  </div>
</div>

<script>
  function initPetModal() {
    const modal = document.getElementById('pet-modal');
    const modalContent = document.getElementById('modal-content');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const modalCaption = document.getElementById('modal-caption');
    const closeBtn = document.getElementById('close-modal');
    const petLinks = document.querySelectorAll('.pet-link');

    const openModal = (imgSrc: string, name: string) => {
      if (!modal || !modalImg || !modalCaption || !modalContent) return;
      
      modalImg.src = imgSrc;
      modalCaption.textContent = name;
      
      // Stop background scrolling
      document.body.style.overflow = 'hidden';
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      
      // Small timeout to allow transition to trigger
      setTimeout(() => {
        modalContent.classList.remove('scale-25', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 10);
    };

    const closeModal = () => {
      if (!modal || !modalContent) return;
      modalContent.classList.add('scale-25', 'opacity-0');
      modalContent.classList.remove('scale-100', 'opacity-100');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        
        // Re-enable background scrolling
        document.body.style.overflow = '';
      }, 200);
    };

    petLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        openModal(target.dataset.img || '', target.textContent || '');
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  // Support for Astro View Transitions
  document.addEventListener('astro:page-load', initPetModal);

  // Simple local time updater for the "fun" desktop section
  function updateTime() {
    const timeEl = document.getElementById('local-time-display');
    if (timeEl) {
      const now = new Date();
      // Specifically targeting America/Chicago for Central Time
      timeEl.textContent = now.toLocaleTimeString('en-US', { 
        hour: '2-digit', 
        minute: '2-digit',
        second: '2-digit',
        hour12: true,
        timeZone: 'America/Chicago' 
      });
    }
  }

  // Handle Astro View Transitions
  document.addEventListener('astro:page-load', () => {
    const interval = setInterval(updateTime, 1000);
    updateTime();
    
    // Cleanup interval on page navigate to prevent memory leaks
    document.addEventListener('astro:before-preparation', () => clearInterval(interval), { once: true });
  });
</script>