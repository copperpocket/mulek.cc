---
// src/components/AboutSummary.astro

interface Props {
  short?: boolean;
}

const { short = false } = Astro.props;

// Career Start Date
const careerStartDate = "2018-12-30"; // Update this to your actual start date

const getAge = (birthDate: string) => {
  const today = new Date();
  const [year, month, day] = birthDate.split('-').map(Number);
  const birth = new Date(year, month - 1, day);
  let age = today.getFullYear() - birth.getFullYear();
  if (today < new Date(today.getFullYear(), month - 1, day)) age--;
  return age;
};

// Logic for a decimal representation (e.g., 6.2)
const getUptime = (startDate: string) => {
  const start = new Date(startDate);
  const now = new Date();
  const diffInMs = now.getTime() - start.getTime();
  const diffInYears = diffInMs / (1000 * 60 * 60 * 24 * 365.25);
  return diffInYears.toFixed(1);
};

const uptime = getUptime(careerStartDate);

const pets = [
  { name: 'Gertie', bday: '09-11', age: getAge("2022-09-11"), img: '/images/gertie1.jpeg' },
  { name: 'Ducky', bday: '04-06', age: getAge("2023-04-06"), img: '/images/ducky1.jpeg' },
  { name: 'Salem', bday: '07-17', age: getAge("2018-07-17") },
  { name: 'Oliver', bday: '02-08', age: getAge("2019-02-08") },
];
---

